<http://example.org/film/tt0012349> a dbo:Film;
  dbo:director <http://example.org/person/charlie_chaplin>;
  dbo:genre <http://example.org/movie-genre/comedy>, <http://example.org/movie-genre/drama>;
  dbo:producer <http://example.org/person/charlie_chaplin>;
  dbo:productionCompany <http://example.org/company/charles_chaplin_productions>, <http://example.org/company/first_national_pictures>;
  dbo:runtime 4.08E3;
  dbo:starring <http://example.org/person/charlie_chaplin>, <http://example.org/person/edna_purviance>,
    <http://example.org/person/jackie_coogan>;
  dbo:title "The Kid (1921)";
  ex:adultOnly false;
  ex:filmAbstract "Considered one of Charlie Chaplin's best films, The Kid also made a star of little Jackie Coogan, who plays a boy cared for by The Tramp when he's abandoned by his mother, Edna. Later, Edna has a change of heart and aches to be reunited with her son. When she finds him and wrests him from The Tramp, it makes for what turns out be one of the most heart-wrenching scenes ever included in a comedy.";
  ex:filmBudget 2.5E5;
  ex:filmImdbId "tt0012349";
  ex:filmMusicBy <http://example.org/person/charlie_chaplin>;
  ex:filmReleaseDate "1921-01-21"^^xsd:date;
  ex:filmWriter <http://example.org/person/charlie_chaplin>;
  ex:hasSong <http://example.org/song/elevation>, <http://example.org/song/fannys_kitchen>,
    <http://example.org/song/heal>, <http://example.org/song/hommage_to_nobuo_uematsu>,
    <http://example.org/song/intro>, <http://example.org/song/it_looks_like_we_dont_have_any_soundtracks_for_this_title_yet>,
    <http://example.org/song/keep_up>, <http://example.org/song/ladybugs_killa>, <http://example.org/song/lifes_bliss>,
    <http://example.org/song/napkid>, <http://example.org/song/night_of_the_living_dub>,
    <http://example.org/song/owari>, <http://example.org/song/someday_baby>, <http://example.org/song/voila>;
  ex:originalLanguage <http://example.org/language/english>;
  ex:popularity "8.168456"^^xsd:float;
  ex:productionCountry <http://example.org/country/united_states_of_america>;
  ex:spokenLanguage <http://example.org/language/no_language>;
  ex:status "Released";
  ex:voteAverage "8"^^xsd:float .

