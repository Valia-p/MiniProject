    <http://example.org/song/frozen>, <http://example.org/song/grauzone>, <http://example.org/song/it_looks_like_we_dont_have_any_soundtracks_for_this_title_yet>,
    <http://example.org/song/oblique_wind>;
  <http://example.org/ontology/originalLanguage> <http://example.org/language/english>;
  <http://example.org/ontology/popularity> "3.80163"^^<http://www.w3.org/2001/XMLSchema#float>;
